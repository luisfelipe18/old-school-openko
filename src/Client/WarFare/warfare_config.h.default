#ifndef CLIENT_WARFARE_CONFIG_H
#define CLIENT_WARFARE_CONFIG_H

#pragma once

// Which login scene shows on startup. Both variants are always compiled in;
// a small toggle in the bottom-left corner of the login scene lets the
// player switch between them at runtime, so this only picks the default.
// Supported values: 1098, 1298
#define LOGIN_SCENE_VERSION 1298

#endif // CLIENT_WARFARE_CONFIG_H
